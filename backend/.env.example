# Backend environment variables for local development
# Copy to .env and fill in values — never commit .env

# DSQL staging cluster (dev/test use staging cluster with admin token)
DSQL_ENDPOINT=your-staging-cluster.dsql.us-east-1.on.aws:5432

# JWT secret (any random string for local dev)
JWT_SECRET=dev-jwt-secret-change-in-prod

# Email (test mode only — no real emails sent when NODE_ENV=test)
EMAIL_FROM={{PROJECT_NAME}} <noreply@{{DOMAIN}}>

# URLs
APP_URL=http://localhost:8080
API_URL=http://localhost:3000

# Optional: set ADMIN_EMAIL to auto-promote that user to admin on email verification
# ADMIN_EMAIL=your-email@example.com
